# Zambia Untold — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# -----------------------------------------------------------------------------
# Supabase (required for community/space submissions and optional notes page)
# -----------------------------------------------------------------------------
# From Supabase Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only: used by API routes for Isibalo + Space Mission writes (bypasses RLS)
# From Supabase Dashboard: Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: override table names (defaults: isibalo_submissions, space_mission_proposals)
# SUPABASE_ISIBALO_TABLE=isibalo_submissions
# SUPABASE_SPACE_MISSIONS_TABLE=space_mission_proposals

# -----------------------------------------------------------------------------
# Vercel: pull with `vercel env pull .env.development.local`
# Add these in Vercel Dashboard → Project → Settings → Environment Variables.
# Use SUPABASE_SERVICE_ROLE_KEY as a secret (sensitive); others as plain.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Moderation API (server-only)
# -----------------------------------------------------------------------------
# Required for /api/moderation/review actions (approve/reject updates)
# Send as x-moderation-token header (or Authorization: Bearer <token>)
MODERATION_API_TOKEN=replace-with-long-random-token
